    "saneui.language.current_language_label" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "App-Sprache" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "App Language" } },
        "es-419" : { "stringUnit" : { "state" : "translated", "value" : "Idioma de la app" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Langue de l’app" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Lingua dell’app" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "アプリの言語" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "앱 언어" } },
        "nl" : { "stringUnit" : { "state" : "translated", "value" : "App-taal" } },
        "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Idioma do app" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "App 语言" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "App 語言" } }
      }
    },
    "saneui.language.helper_text" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Ändere die App-Sprache in den Systemeinstellungen. Starte die App neu, falls macOS die Oberfläche noch nicht aktualisiert hat." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Change the app language in System Settings. Restart the app if macOS has not refreshed the UI yet." } },
        "es-419" : { "stringUnit" : { "state" : "translated", "value" : "Cambia el idioma de la app en Configuración del Sistema. Reinicia la app si macOS aún no actualizó la interfaz." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Modifiez la langue de l’app dans Réglages Système. Redémarrez l’app si macOS n’a pas encore actualisé l’interface." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Cambia la lingua dell’app nelle Impostazioni di Sistema. Riavvia l’app se macOS non ha ancora aggiornato l’interfaccia." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "システム設定でアプリの言語を変更します。macOS がまだ UI を更新していない場合は、アプリを再起動してください。" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "시스템 설정에서 앱 언어를 변경하세요. macOS가 아직 UI를 새로 고치지 않았다면 앱을 다시 시작하세요." } },
        "nl" : { "stringUnit" : { "state" : "translated", "value" : "Wijzig de app-taal in Systeeminstellingen. Start de app opnieuw als macOS de interface nog niet heeft bijgewerkt." } },
        "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Altere o idioma do app nos Ajustes do Sistema. Reinicie o app se o macOS ainda não atualizou a interface." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "请在系统设置中更改 App 语言。如果 macOS 尚未刷新界面，请重新启动 App。" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "請在系統設定中更改 App 語言。如果 macOS 尚未更新介面，請重新啟動 App。" } }
      }
    },
