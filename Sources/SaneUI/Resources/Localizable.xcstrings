    "saneui.language.single_language_helper_text" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Füge weitere App-Sprachen hinzu, um die sprachspezifische App-Auswahl in den Systemeinstellungen zu aktivieren." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Add more app localizations to enable per-app language switching in System Settings." } },
        "es-419" : { "stringUnit" : { "state" : "translated", "value" : "Agrega más localizaciones de la app para habilitar el cambio de idioma por app en Configuración del Sistema." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Ajoutez d’autres localisations de l’app pour activer le changement de langue par app dans Réglages Système." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Aggiungi altre localizzazioni dell’app per abilitare il cambio lingua per app nelle Impostazioni di Sistema." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "システム設定でアプリごとの言語切り替えを有効にするには、アプリのローカライズを追加してください。" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "시스템 설정에서 앱별 언어 전환을 사용하려면 앱 현지화를 더 추가하세요." } },
        "nl" : { "stringUnit" : { "state" : "translated", "value" : "Voeg meer app-localisaties toe om per-app taalkeuze in Systeeminstellingen mogelijk te maken." } },
        "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Adicione mais localizações do app para permitir a troca de idioma por app nos Ajustes do Sistema." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "添加更多 App 本地化后，才能在系统设置中启用按 App 切换语言。" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "新增更多 App 在地化後，才能在系統設定中啟用每個 App 的語言切換。" } }
      }
    },
